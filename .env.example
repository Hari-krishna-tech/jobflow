# JobFlow — environment variables
# Copy to .env.local and fill in. See PLAN.html §16.
# NEVER commit .env.local.

# Neon Postgres connection string (prisma.config.ts + PrismaClient adapter).
DATABASE_URL=

# Auth.js (NextAuth v5) session signing secret. Generate: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials (Phase 1.6+).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# App base URL (Vercel domain in prod, http://localhost:3000 in dev).
NEXTAUTH_URL=http://localhost:3000

# OpenRouter — AI email classification (Phase 3).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b

# Key for encrypting Gmail refresh tokens at rest (Phase 2.2).
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
